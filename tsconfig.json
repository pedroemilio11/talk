{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@fluxi/design-system": ["packages/design-system/src/index.ts"],
      "@fluxi/design-system/*": ["packages/design-system/src/*"],
      "@fluxi/ui": ["packages/ui/src/index.ts"],
      "@fluxi/ui/*": ["packages/ui/src/*"],
      "@fluxi/shared-types": ["packages/shared-types/src/index.ts"],
      "@fluxi/module-sdk": ["packages/module-sdk/src/index.ts"],
      "@fluxi/modules/*": ["modules/*/src/index.ts"]
    }
  }
}
